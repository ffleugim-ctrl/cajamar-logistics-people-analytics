  AUTOR: Miguel Dantas
*******************************************************************************/

-- 1. Criação e inicialização do banco de dados
USE estudos_analytics;
GO

-- 2. Garantia de Idempotência (Limpeza de tabelas antigas se existirem)
DROP TABLE IF EXISTS escalas_turno;
DROP TABLE IF EXISTS funcionarios_cd;
GO

-- 3. Criação da tabela dimensional de cadastro de colaboradores
CREATE TABLE funcionarios_cd (
    id_func INT PRIMARY KEY,
    nome VARCHAR(100),
    setor VARCHAR(50)
);
GO

-- 4. Criação da tabela dimensional de escalas e turnos operacionais
CREATE TABLE escalas_turno (
    id_func INT,
    turno VARCHAR(10),
    escala VARCHAR(10),
    FOREIGN KEY (id_func) REFERENCES funcionarios_cd(id_func)
);
GO

