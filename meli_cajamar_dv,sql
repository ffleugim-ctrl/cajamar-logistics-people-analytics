-- 6. Camada de Consulta Analítica (Modelagem Semântica para o BI)
SELECT 
    f.id_func AS [ID Colaborador],
    f.nome AS [Nome],
    f.setor AS [Subsetor DV],
    e.turno AS [Turno],
    e.escala AS [Escala]
FROM funcionarios_cd f
INNER JOIN escalas_turno e ON f.id_func = e.id_func;
